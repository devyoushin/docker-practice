{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker inspect*)",
      "Bash(docker logs*)",
      "Bash(docker stats*)",
      "Bash(docker network ls*)",
      "Bash(docker volume ls*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)"
    ],
    "deny": [
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker system prune*)",
      "Bash(docker compose down*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo $CLAUDE_TOOL_INPUT | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); [ -n \"$file\" ] && echo \"[docker-practice] 저장: $(basename $file)\""
          }
        ]
      }
    ]
  }
}
